-- Chờ game load xong hoàn toàn
if not game:IsLoaded() then game.Loaded:Wait() end

-- Đảm bảo chỉ chạy 1 lần duy nhất để không spam F9
if _G.SingleCheckExecuted then return end
_G.SingleCheckExecuted = true

local Acc1, Acc2 = "doanhlo", "ddjsjcosc"
local LocalPlayer = game.Players.LocalPlayer
local target = (LocalPlayer.Name == Acc1) and Acc2 or Acc1

local function ExecuteHop()
    local success, result = pcall(function() 
        -- Lấy danh sách 100 server đông nhất
        return game:HttpGet("https://games.roblox.com/v1/games/"..game.PlaceId.."/servers/Public?sortOrder=Desc&limit=100") 
    end)
    
    if success then
        local servers = game:GetService("HttpService"):JSONDecode(result)
        local candidates = {}

        for _, v in pairs(servers.data) do
            -- ĐIỀU KIỆN TÌM SERVER ĐÔNG:
            -- 1. Server còn chỗ trống (v.playing < v.maxPlayers)
            -- 2. Server phải có ít nhất 8 người để đảm bảo đông vui
            -- 3. Không phải server hiện tại (v.id ~= game.JobId)
            if v.playing < v.maxPlayers and v.playing >= 8 and v.id ~= game.JobId then
                table.insert(candidates, v.id)
            end
        end

        -- Nếu tìm thấy danh sách server đông, chọn ngẫu nhiên 1 cái để nhảy
        if #candidates > 0 then
            local randomServer = candidates[math.random(1, #candidates)]
            game:GetService("TeleportService"):TeleportToPlaceInstance(game.PlaceId, randomServer, LocalPlayer)
        else
            -- Nếu không có server nào trên 8 người, hạ tiêu chuẩn xuống 6 người
            for _, v in pairs(servers.data) do
                if v.playing > 5 and v.id ~= game.JobId then
                    game:GetService("TeleportService"):TeleportToPlaceInstance(game.PlaceId, v.id, LocalPlayer)
                    break
                end
            end
        end
    end
end

-- Chạy script từ GitHub của cậu
task.spawn(function()
    pcall(function() loadstring(game:HttpGet("https://raw.githubusercontent.com/doanhnoff-sketch/severhop/refs/heads/main/idk"))() end)
end)

-- BƯỚC KIỂM TRA DUY NHẤT LÚC VÀO SERVER
local isTargetHere = false
for _, p in pairs(game.Players:GetPlayers()) do
    if p.Name == target then
        isTargetHere = true
        break
    end
end

if isTargetHere then
    -- Thấy acc phụ là nhảy luôn
    ExecuteHop()
else
    -- Không thấy thì 10 phút sau mới nhảy để tìm server đông hơn
    print("✅ Server an toàn. Sẽ tìm server đông sau 10 phút.")
    task.delay(600, function()
        ExecuteHop()
    end)
end
