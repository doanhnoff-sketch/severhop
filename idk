-- Chờ game load
if not game:IsLoaded() then game.Loaded:Wait() end

-- Chặn chạy đè
if _G.MaxHopExecuted then return end
_G.MaxHopExecuted = true

local Acc1, Acc2 = "doanhlo", "ddjsjcosc"
local LocalPlayer = game.Players.LocalPlayer
local target = (LocalPlayer.Name == Acc1) and Acc2 or Acc1

local function ExecuteMaxHop()
    local success, result = pcall(function() 
        return game:HttpGet("https://games.roblox.com/v1/games/"..game.PlaceId.."/servers/Public?sortOrder=Desc&limit=100") 
    end)
    
    if success then
        local servers = game:GetService("HttpService"):JSONDecode(result)
        
        for _, v in pairs(servers.data) do
            -- Chỉ thử các server còn ít nhất 1-2 chỗ trống để tránh lỗi full khi đang load
            if v.playing < 31 and v.id ~= game.JobId then
                local teleported = false
                
                -- Lệnh nhảy server
                game:GetService("TeleportService"):TeleportToPlaceInstance(game.PlaceId, v.id, LocalPlayer)
                
                -- Nếu sau 6 giây vẫn chưa rời khỏi server cũ (nhảy thất bại vì full)
                task.wait(6)
                -- Tiếp tục thử server tiếp theo trong danh sách
            end
        end
        
        -- Nếu chạy hết danh sách mà vẫn k vô được, load lại danh sách mới sau 2s
        task.wait(2)
        ExecuteMaxHop()
    else
        task.wait(3)
        ExecuteMaxHop()
    end
end

-- Kiểm tra acc phụ lúc mới vào
local isTargetHere = false
for _, p in pairs(game.Players:GetPlayers()) do
    if p.Name == target then
        isTargetHere = true
        break
    end
end

if isTargetHere then
    ExecuteMaxHop()
else
    -- Treo đúng 10p rồi nhảy server đông nhất
    task.delay(600, function()
        ExecuteMaxHop()
    end)
end
