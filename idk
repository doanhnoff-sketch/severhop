-- Chờ game load xong hoàn toàn
if not game:IsLoaded() then game.Loaded:Wait() end

-- Đảm bảo chỉ chạy 1 lần duy nhất để không spam F9
if _G.SingleCheckExecuted then return end
_G.SingleCheckExecuted = true

local Acc1, Acc2 = "doanhlo", "ddjsjcosc"
local LocalPlayer = game.Players.LocalPlayer
local target = (LocalPlayer.Name == Acc1) and Acc2 or Acc1

local function ExecuteHop()
    local success, result = pcall(function() 
        return game:HttpGet("https://games.roblox.com/v1/games/"..game.PlaceId.."/servers/Public?sortOrder=Desc&limit=100") 
    end)
    if success then
        local servers = game:GetService("HttpService"):JSONDecode(result)
        for _, v in pairs(servers.data) do
            if v.playing < v.maxPlayers and v.playing > 5 and v.id ~= game.JobId then
                game:GetService("TeleportService"):TeleportToPlaceInstance(game.PlaceId, v.id, LocalPlayer)
                break
            end
        end
    end
end

-- Chạy script từ GitHub của cậu
task.spawn(function()
    pcall(function() loadstring(game:HttpGet("https://raw.githubusercontent.com/doanhnoff-sketch/severhop/refs/heads/main/idk"))() end)
end)

-- BƯỚC KIỂM TRA DUY NHẤT LÚC VÀO SERVER
local isTargetHere = false
for _, p in pairs(game.Players:GetPlayers()) do
    if p.Name == target then
        isTargetHere = true
        break
    end
end

if isTargetHere then
    -- Thấy là nhảy luôn, không chờ đợi
    ExecuteHop()
else
    -- Không thấy thì treo máy đúng 10p sau mới nhảy tiếp
    print("✅ Sạch bóng " .. target .. ". Sẽ tự động Hop sau 10 phút.")
    task.delay(600, function()
        ExecuteHop()
    end)
end
