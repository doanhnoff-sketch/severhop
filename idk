end)

-- Hop định kỳ mỗi 10 phút
task.spawn(function()
    while task.wait(600) do ExecuteHop() end
end)

-- Né acc phụ ngay lập tức
local function Check()
    for _, p in pairs(game.Players:GetPlayers()) do
        if p.Name == targetToAvoid then ExecuteHop() end
    end
end

Check()
game.Players.PlayerAdded:Connect(function(player)
    if player.Name == targetToAvoid then ExecuteHop() end
