-- Reset chặn
_G.MaxHopExecuted = nil 

if not game:IsLoaded() then game.Loaded:Wait() end
if _G.MaxHopExecuted then return end
_G.MaxHopExecuted = true

local Acc1, Acc2 = "doanhlo", "ddjsjcosc"
local LocalPlayer = game.Players.LocalPlayer
local target = (LocalPlayer.Name == Acc1) and Acc2 or Acc1

local function ExecuteMaxHop()
    local success, result = pcall(function() 
        return game:HttpGet("https://games.roblox.com/v1/games/"..game.PlaceId.."/servers/Public?sortOrder=Desc&limit=100") 
    end)
    
    if success then
        local servers = game:GetService("HttpService"):JSONDecode(result).data
        
        -- Sắp xếp lại danh sách để chắc chắn server đông nhất nằm đầu tiên
        table.sort(servers, function(a, b)
            return a.playing > b.playing
        end)

        for _, v in pairs(servers) do
            -- Tiêu chí: Đông nhất nhưng phải dưới 32 và không phải server cũ
            if v.playing < 32 and v.id ~= game.JobId then
                game:GetService("TeleportService"):TeleportToPlaceInstance(game.PlaceId, v.id, LocalPlayer)
                
                -- Đợi 6s để kiểm tra xem có vào được không
                task.wait(6)
                -- Nếu vẫn còn ở đây thì vòng lặp for sẽ tự thử server đông thứ 2, thứ 3...
            end
        end
        
        -- Nếu thử hết 100 cái vẫn không xong thì load lại
        task.wait(2)
        ExecuteMaxHop()
    else
        task.wait(3)
        ExecuteMaxHop()
    end
end

-- Kiểm tra acc phụ lúc vào
local isTargetHere = false
for _, p in pairs(game.Players:GetPlayers()) do
    if p.Name == target then isTargetHere = true break end
end

if isTargetHere then
    ExecuteMaxHop()
else
    -- Treo 10p rồi mới tìm server đông nhất để nhảy
    task.delay(600, function()
        ExecuteMaxHop()
    end)
end
