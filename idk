if not game:IsLoaded() then game.Loaded:Wait() end

-- Cấu hình 2 acc của cậu
local Acc1 = "doanhlo"
local Acc2 = "ddjsjcosc"
local LocalPlayer = game.Players.LocalPlayer
local targetToAvoid = (LocalPlayer.Name == Acc1) and Acc2 or Acc1

local function ExecuteHop()
    local HttpService = game:GetService("HttpService")
    local url = "https://games.roblox.com/v1/games/"..game.PlaceId.."/servers/Public?sortOrder=Desc&limit=100"
    local success, result = pcall(function() return game:HttpGet(url) end)
    if success then
        local servers = HttpService:JSONDecode(result)
        for _, v in pairs(servers.data) do
            -- Tìm server đông (>5 người) và không phải server hiện tại
            if v.playing < v.maxPlayers and v.playing > 5 and v.id ~= game.JobId then
                game:GetService("TeleportService"):TeleportToPlaceInstance(game.PlaceId, v.id, LocalPlayer)
                break
            end
        end
    end
end

-- Chạy script gốc của cậu
task.spawn(function()
    pcall(function() loadstring(game:HttpGet("https://raw.githubusercontent.com/doanhnoff-sketch/severhop/refs/heads/main/idk"))() end)
end)

-- CHỈ KIỂM TRA MỘT LẦN DUY NHẤT KHI VỪA VÀO SERVER
local function CheckOnce()
    for _, p in pairs(game.Players:GetPlayers()) do
        if p.Name == targetToAvoid then 
            ExecuteHop() 
            return -- Thoát hàm ngay sau khi kích hoạt Hop
        end
    end
end

-- Thực hiện kiểm tra
CheckOnce()

print("Hệ thống đã kiểm tra né " .. targetToAvoid .. " xong.")[cite: 1]
